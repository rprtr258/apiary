{
  "name": "apiary",
  "version": "0.0.1",
  "main": "dist-electron/main.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint '**/*.{ts,json}'",
    "lint:fix": "eslint --fix '**/*.{ts,json}'",
    "ci": "bun run scripts/ci.ts",
    "test": "bun test --preload ./frontend/test.setup.ts ''",
    "test:e2e": "playwright test",
    "dist": "vite build && electron-builder",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.5",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.4.0",
    "@codemirror/lang-sql": "^6.9.0",
    "@fsegurai/codemirror-theme-github-dark": "^6.2.3",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.1",
    "@types/sanitize-html": "^2.16.1",
    "codemirror": "^6.0.1",
    "codemirror-json-schema": "^0.8.1",
    "diff": "^9.0.0",
    "electron": "^42.0.1",
    "golden-layout": "^2.6.0",
    "jq-wasm": "^1.1.0-jq-1.8.1",
    "marked": "^18.0.3",
    "mysql2": "^3.22.3",
    "nanoid": "^5.1.11",
    "openapi-types": "^12.1.3",
    "perfect-arrows": "^0.3.7",
    "pg": "^8.20.0",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.4",
    "split-grid": "^1.0.11",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.5",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.2",
    "eslint-config-standard-with-typescript": "^42.0.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.4.0",
    "eslint-plugin-promise": "^6.1.1",
    "happy-dom": "^20.3.4",
    "jiti": "^2.6.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "vite": "^6.0.11",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "build": {
    "appId": "com.apiary.app",
    "productName": "apiary",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "artifactName": "apiary-linux-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "apiary-darwin-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "apiary-win-${arch}.${ext}"
    }
  }
}
