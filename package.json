{
  "name": "apiary",
  "version": "0.0.4",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": {
    "name": "Poletansky Viktor",
    "email": "poletansky@gmail.com"
  },
  "private": true,
  "scripts": {
    "dev": "vite --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint '**/*.{ts,json}'",
    "lint:fix": "eslint --fix '**/*.{ts,json}'",
    "ci": "bun run scripts/ci.ts",
    "test": "bun test --preload ./renderer/test.setup.ts --path-ignore-patterns=renderer/e2e/* --path-ignore-patterns=main/integration.test.ts ''",
    "test:integration": "bun test integration.test.ts",
    "test:e2e": "playwright test",
    "dist": "vite build && electron-builder",
    "dist:linux": "vite build && electron-builder --linux",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win",
    "typecheck": "tsc --noEmit",
    "_start": "vite build && electron .",
    "gen:grpc": "grpc_tools_node_protoc --plugin=protoc-gen-ts=./node_modules/.bin/protoc-gen-ts --ts_out=grpc_js:./ --js_out=import_style=commonjs,binary:./ --grpc_out=grpc_js:./ ./scripts/grpc/helloworld.proto && sed -i '1i/* eslint-disable */' ./scripts/grpc/helloworld.ts && sed -i '2i// @ts-nocheck' ./scripts/grpc/helloworld.ts",
    "kal": "electron-rebuild"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@clickhouse/client": "^1.20.0",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-sql": "^6.10.0",
    "@electron/rebuild": "^4.0.4",
    "@fsegurai/codemirror-theme-github-dark": "^6.2.5",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@types/sanitize-html": "^2.16.1",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.11.1",
    "codemirror": "^6.0.2",
    "codemirror-json-schema": "^0.8.1",
    "diff": "^9.0.0",
    "golden-layout": "^2.6.0",
    "jq-wasm": "^1.1.0-jq-1.8.1",
    "marked": "^18.0.5",
    "mysql2": "^3.22.5",
    "nanoid": "^5.1.11",
    "openapi-types": "^12.1.3",
    "perfect-arrows": "^0.3.7",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "sanitize-html": "^2.17.5",
    "split-grid": "^1.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@grpc/reflection": "^1.0.4",
    "@playwright/test": "^1.60.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/bun": "^1.3.14",
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-standard-with-typescript": "^42.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.6.0",
    "google-protobuf": "^4.0.2",
    "grpc-tools": "^1.13.1",
    "happy-dom": "^20.10.3",
    "jiti": "^2.7.0",
    "protoc-gen-ts": "^0.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.4.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "build": {
    "appId": "com.apiary.app",
    "productName": "apiary",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "artifactName": "apiary-linux-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "apiary-darwin-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "apiary-win-${arch}.${ext}"
    }
  }
}
